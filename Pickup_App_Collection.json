"name": "1. Login",
"event": [
{
"listen": "test",
"script": {
"exec": [
"if (pm.response.code === 200) {",
"    var responseData = pm.response.json();",
"    if (responseData && responseData.token) {",
"        pm.collectionVariables.set(\"token\", responseData.token);",
"        console.log(\"Authentication token saved.\");",
"    }",
"}"
],
"type": "text/javascript"
}
}
],
