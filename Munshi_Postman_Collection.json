{
    "info": {
        "name": "VaxTrack — Munshi (Packing Supervisor) Module",
        "_postman_id": "vaxtrack-munshi-v1-2026",
        "description": "Complete Munshi API collection for VaxTrack. Login first (folder 0) to auto-capture the token into {{munshiToken}}. Set {{baseUrl}} = http://localhost:5000 in your environment.\n\n## E2E\nUse {{assignmentId}} = Logistics _id from OM dispatch. POST /api/munshi/packing/{{assignmentId}}.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000",
            "type": "string"
        },
        {
            "key": "munshiToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "assignmentId",
            "value": "",
            "type": "string"
        },
        {
            "key": "pickupDriverId",
            "value": "",
            "type": "string"
        },
        {
            "key": "brandId",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "0. Auth",
            "item": [
                {
                    "name": "Login as Munshi",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "if (res.token) {",
                                    "  pm.collectionVariables.set('munshiToken', res.token);",
                                    "  console.log('Munshi Token captured:', res.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"mobileNo\": \"0000000004\",\n  \"password\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/users/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "login"
                            ]
                        },
                        "description": "Login and auto-capture token into {{munshiToken}} via test script."
                    }
                },
                {
                    "name": "GET My Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/users/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "me"
                            ]
                        },
                        "description": "Returns the logged-in Munshi's profile (name, role, mobile). Use to display \"Welcome, [Name]\" in the app header."
                    }
                },
                {
                    "name": "POST Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/users/logout",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "logout"
                            ]
                        },
                        "description": "Writes a LOGOUT audit log entry. Client must delete the stored token after this call (JWT is stateless)."
                    }
                }
            ]
        },
        {
            "name": "1. Daily Logs",
            "item": [
                {
                    "name": "GET Check Today Log Status",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/daily-logs/check-today",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "daily-logs",
                                "check-today"
                            ]
                        },
                        "description": "🚦 CALL THIS FIRST ON APP OPEN.\n\nChecks if the logged-in Munshi has already submitted a Start Day log for today.\n\n- `isStarted: true`  → skip the meter photo screen, jump to dashboard.\n- `isStarted: false` → show the Start Day / Meter Photo screen.\n\nResponse:\n```json\n// Day already started:\n{ \"isStarted\": true, \"logId\": \"<ObjectId>\", \"role\": \"Munshi\" }\n\n// Day not started:\n{ \"isStarted\": false }\n```"
                    },
                    "response": []
                },
                {
                    "name": "POST Start Day Log",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "startKm",
                                    "value": "13140",
                                    "type": "text",
                                    "description": "Odometer reading at start of day — REQUIRED"
                                },
                                {
                                    "key": "vehicleNumber",
                                    "value": "MH-15-E2E-5505",
                                    "type": "text",
                                    "description": "Vehicle registration number — optional"
                                },
                                {
                                    "key": "startKmPhoto",
                                    "type": "file",
                                    "src": "",
                                    "description": "Odometer photo at start of day — REQUIRED. Attach an image file."
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/daily-logs/start",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "daily-logs",
                                "start"
                            ]
                        },
                        "description": "Submits the morning odometer reading to start the day's log.\n\n- Returns 400 if the Munshi already has an active log for today (use check-today first).\n- `vehicleNumber` is optional."
                    },
                    "response": []
                },
                {
                    "name": "PATCH End Day Log",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "endKm",
                                    "value": "13290",
                                    "type": "text",
                                    "description": "Odometer reading at end of day — REQUIRED. Must be greater than startKm."
                                },
                                {
                                    "key": "endKmPhoto",
                                    "type": "file",
                                    "src": "",
                                    "description": "Odometer photo at end of day — REQUIRED. Attach an image file."
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/daily-logs/end",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "daily-logs",
                                "end"
                            ]
                        },
                        "description": "Closes the active daily log for today.\n\n- Returns 404 if no active (STARTED) log exists for today.\n- Returns 400 if endKm ≤ startKm.\n\n⚠️ This is a PATCH request, not PUT."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "2. Dashboard",
            "item": [
                {
                    "name": "GET Munshi Dashboard",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/dashboard",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "dashboard"
                            ]
                        },
                        "description": "Returns KPIs scoped to the logged-in Munshi: pickups (PENDING+IN_PROGRESS), completed, cancelled, total. Also returns activeAssignments[] populated with farmer, company, driver, vehicle, and light-in/out times."
                    }
                }
            ]
        },
        {
            "name": "2. Assignments List",
            "item": [
                {
                    "name": "GET Assignments — Pickups (PENDING + IN_PROGRESS)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments?status=PENDING&page=1&limit=20",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments"
                            ],
                            "query": [
                                {
                                    "key": "status",
                                    "value": "PENDING",
                                    "description": "Options: PENDING, IN_PROGRESS, COMPLETED, CANCELLED. Omit for all."
                                },
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                }
                            ]
                        },
                        "description": "Paginated list of assignments for the logged-in Munshi. Populated with farmer details, company, driver, pickup driver, vehicle. Use the status query param to power Pickups / Completed / Cancelled tabs."
                    }
                },
                {
                    "name": "GET Assignments — Completed",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments?status=COMPLETED&page=1&limit=20",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments"
                            ],
                            "query": [
                                {
                                    "key": "status",
                                    "value": "COMPLETED"
                                },
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                }
                            ]
                        },
                        "description": "Completed assignments — Munshi submitted packing report and assignment was marked COMPLETED."
                    }
                },
                {
                    "name": "GET Assignments — Cancelled",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments?status=CANCELLED&page=1&limit=20",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments"
                            ],
                            "query": [
                                {
                                    "key": "status",
                                    "value": "CANCELLED"
                                },
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                }
                            ]
                        },
                        "description": "Cancelled assignments — Munshi cancelled the packing from the field."
                    }
                }
            ]
        },
        {
            "name": "OM Rejection / Resubmit Flow",
            "item": [
                {
                    "name": "Get Rejected Assignments",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments?status=REJECTED",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments"
                            ],
                            "query": [
                                {
                                    "key": "status",
                                    "value": "REJECTED",
                                    "description": "Logistics assignments the OM has rejected — Munshi fixes packing and resubmits."
                                }
                            ]
                        },
                        "description": "Fetches the list of logistics assignments that the OM has rejected. Munshi uses this to see what needs fixing."
                    }
                },
                {
                    "name": "Get Packing Report Details",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments/{{assignmentId}}/packing",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments",
                                "{{assignmentId}}",
                                "packing"
                            ]
                        },
                        "description": "Fetches the existing packing report for a specific assignment. Crucial for reading the `omRemark` left by the Operational Manager so the Munshi knows exactly what to fix."
                    }
                }
            ]
        },
        {
            "name": "3. Assign Pickup Driver",
            "item": [
                {
                    "name": "PATCH Assign Pickup Driver",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"pickupDriverId\": \"{{pickupDriverId}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments/{{assignmentId}}/pickup",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments",
                                "{{assignmentId}}",
                                "pickup"
                            ]
                        },
                        "description": "Assigns a secondary pickup driver to the assignment.\n\nVALIDATION:\n- Assignment must belong to the logged-in Munshi\n- Assignment must not be COMPLETED or CANCELLED\n- pickupDriverId must be a user with a 'driver' role\n\nSide effects:\n- Transitions assignmentStatus from PENDING → IN_PROGRESS\n- Sends WhatsApp alert to the pickup driver"
                    }
                },
                {
                    "name": "POST Rollover Assignment (Next Day)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nextDate\": \"2026-04-18\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments/{{assignmentId}}/rollover",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments",
                                "{{assignmentId}}",
                                "rollover"
                            ]
                        },
                        "description": "Clones the current dispatch to the next harvest day with the exact same Munshi, Driver, Pickup Driver, and Vehicle. Fresh assignmentStatus = PENDING. isRollover = true. parentAssignmentId links back to today's assignment.\n\nGUARDS:\n- nextDate is required (YYYY-MM-DD)\n- Cannot roll over a CANCELLED assignment\n- Only works for your own assignments (or Admin)\n\nAfter rolling over, submit a new packing report against the returned assignment _id."
                    },
                    "response": []
                },
                {
                    "name": "POST Add Extra Vehicle (Overflow)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"driverId\": \"REPLACE_WITH_EXTRA_DRIVER_ID\",\n  \"munshiId\": \"OPTIONAL_DIFFERENT_MUNSHI_ID\",\n  \"companyId\": \"OPTIONAL_OVERRIDE_COMPANY_ID\",\n  \"purchaseRate\": 918,\n  \"totalBoxes\": 200,\n  \"priority\": \"HIGH\",\n  \"lightInTime\": \"05:00 AM\",\n  \"lightOutTime\": \"07:00 AM\",\n  \"teamName\": \"Overflow Crew-01\",\n  \"scheduledDate\": \"2026-04-30\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments/{{assignmentId}}/add-vehicle",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments",
                                "{{assignmentId}}",
                                "add-vehicle"
                            ]
                        },
                        "description": "Add an extra vehicle to an existing assignment when the original vehicle is full.\n\nCreates a new overflow Logistics record with isOverflow=true, parentAssignmentId pointing to the original.\n\nRequired: driverId\nOptional (defaults to original assignment values if omitted): munshiId, companyId, purchaseRate, totalBoxes, priority, lightInTime, lightOutTime, teamName, scheduledDate\n\nWhatsApp notifications sent to: extra driver, assigned munshi, and original driver.\n\nThe overflow appears as a separate assignment in the Munshi dashboard. Munshi submits a separate packing report for each vehicle using POST /api/munshi/packing/:overflowAssignmentId.\n\nAlso available via: POST /api/logistics/:id/add-vehicle"
                    },
                    "response": []
                },
                {
                    "name": "GET Related Assignments (Original + Rollovers + Overflows)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/logistics/{{assignmentId}}/related",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "logistics",
                                "{{assignmentId}}",
                                "related"
                            ]
                        },
                        "description": "Returns the full chain for any assignment: the root original assignment, all rollovers (extra days), and all overflows (extra vehicles). Walks up parentAssignmentId to find the root, then fetches all descendants.\n\nResponse: { original, rollovers[], overflows[], totalRelated }\n\nUseful for seeing all vehicles and days associated with one enquiry."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "3. Packing Report",
            "item": [
                {
                    "name": "POST Submit Packing Report (Success)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "box13_5Kg",
                                    "value": "400",
                                    "type": "text",
                                    "description": "13.5Kg box count"
                                },
                                {
                                    "key": "box5Kg",
                                    "value": "50",
                                    "type": "text",
                                    "description": "5Kg box count"
                                },
                                {
                                    "key": "totalBoxes",
                                    "value": "450",
                                    "type": "text",
                                    "description": "Must equal sum of all box types"
                                },
                                {
                                    "key": "wastageKg",
                                    "value": "8",
                                    "type": "text",
                                    "description": "Wastage in kg (optional, defaults to 0)"
                                },
                                {
                                    "key": "remarks",
                                    "value": "E2E Apr 2026 run — line stable, humidity normal.",
                                    "type": "text",
                                    "description": "Optional Munshi notes"
                                },
                                {
                                    "key": "lineNo",
                                    "value": "7",
                                    "type": "text",
                                    "description": "NEW — Packing line number"
                                },
                                {
                                    "key": "teamName",
                                    "value": "E2E Crew North-04",
                                    "type": "text",
                                    "description": "NEW — Harvesting team name"
                                },
                                {
                                    "key": "brandId",
                                    "value": "",
                                    "type": "text",
                                    "description": "Optional: set collection variable brandId from master-data, or leave empty"
                                },
                                {
                                    "key": "photos",
                                    "src": "",
                                    "type": "file",
                                    "description": "Packing photo 1 (up to 10 files allowed)"
                                },
                                {
                                    "key": "photos",
                                    "src": "",
                                    "type": "file",
                                    "description": "Packing photo 2"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/packing/{{assignmentId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "packing",
                                "{{assignmentId}}"
                            ]
                        },
                        "description": "Submits a completed packing report for an assignment.\n\n**⏱ 24-HOUR GUARD:** Submission is only allowed within 24 hours of assignment creation. Returns 403 after that window.\n\nSide effects:\n- Packing status → SUBMITTED\n- Logistics assignmentStatus → COMPLETED (awaiting OM packing approve/reject)\n- Enquiry stays IN_PROGRESS until OM **Approve Packing** (then Enquiry → COMPLETED)\n- WhatsApp packing summary sent to farmer\n\nVALIDATION:\n- totalBoxes must equal the sum of all box types\n- `wastageReason` is no longer required (removed 2026-05-05)\n- Prevents duplicate submissions"
                    }
                },
                {
                    "name": "POST Cancel Assignment (via Packing)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"cancellationReason\": \"Farmer refused at site. Bananas not ready for harvest — too green.\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/packing/{{assignmentId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "packing",
                                "{{assignmentId}}"
                            ]
                        },
                        "description": "Cancels an assignment from the field.\n\nSide effects:\n- Packing status → CANCELLED\n- Logistics assignmentStatus → CANCELLED\n- Enquiry status → CANCELLED\n\nOnly send `cancellationReason` in the body — no box counts needed."
                    }
                },
                {
                    "name": "GET Packing Report (Fetch for Edit/Reject)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/munshi/assignments/{{assignmentId}}/packing",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "munshi",
                                "assignments",
                                "{{assignmentId}}",
                                "packing"
                            ]
                        },
                        "description": "Fetches an existing packing report (especially after OM rejection).\n\nReturns the full packing document including:\n- All box counts (box4H, box5H, etc.)\n- Photos array (file paths)\n- status ('SUBMITTED', 'REJECTED', etc.)\n- **omRemark** — The OM's rejection comment (if status = REJECTED)\n- Wastage details (wastageKg)\n- Brand, team, line info\n\nUsed by the mobile app to pre-fill the Packing form when resubmitting after rejection."
                    }
                },
                {
                    "name": "PUT Update Packing Report (Resubmit)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{munshiToken}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "box13_5Kg",
                                    "value": "400",
                                    "type": "text",
                                    "description": "Corrected 13.5Kg box count"
                                },
                                {
