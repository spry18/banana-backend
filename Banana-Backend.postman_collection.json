{
  "info": {
    "_postman_id": "banana-backend-2026",
    "name": "Banana Backend API",
    "description": "Complete API collection for Banana Transport Backend - Operational Manager, Munshi, Logistics, and Enquiry flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "User login endpoint. Returns JWT token."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Munshi Dropdown",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users?role=Munshi",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ],
              "query": [
                {
                  "key": "role",
                  "value": "Munshi"
                }
              ]
            },
            "description": "Fetches a list of all Munshi users to populate the dropdown for team assignment."
          }
        }
      ]
    },
    {
      "name": "Operational Manager",
      "item": [
        {
          "name": "Get OM Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/operational-manager/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "operational-manager",
                "dashboard"
              ]
            },
            "description": "Get OM Dashboard KPIs: fixedPlots, teamsAssigned, activeTrips, approvedTrips, pendingReview + recent activity feed."
          }
        },
        {
          "name": "Get Plots Pipeline",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/operational-manager/plots?stage=All&page=1&limit=20&search=",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "operational-manager",
                "plots"
              ],
              "query": [
                {
                  "key": "stage",
                  "value": "All",
                  "description": "All | Unassigned | Assigned | Complete"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "search",
                  "value": ""
                }
              ]
            },
            "description": "Get plots pipeline with filtering:\n- All: RATE_FIXED + ASSIGNED enquiries with logistics (if any)\n- Unassigned: RATE_FIXED with no logistics\n- Assigned: Logistics with assignmentStatus PENDING or IN_PROGRESS\n- Complete: Logistics with assignmentStatus COMPLETED or REJECTED"
          }
        },
        {
          "name": "Reject Packing Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remark\": \"Box counts do not match the photos. Please fix.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/operational-manager/assignments/:assignmentId/reject",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "operational-manager",
                "assignments",
                ":assignmentId",
                "reject"
              ],
              "variable": [
                {
                  "key": "assignmentId",
                  "value": "",
                  "description": "Logistics assignment ID"
                }
              ]
            },
            "description": "Reject a submitted packing report. Changes Packing status to REJECTED and Logistics assignmentStatus to REJECTED. Munshi can then resubmit with corrections.\n\nRequest body: { \"remark\": \"string\" } - Required: remark describing the rejection reason."
          }
        }
      ]
    },
    {
      "name": "Logistics",
      "item": [
        {
          "name": "Assign Team",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enquiryId\": \"507f1f77bcf86cd799439011\",\n  \"companyId\": \"507f1f77bcf86cd799439012\",\n  \"packingType\": \"4H\",\n  \"totalBoxes\": 1600,\n  \"munshiId\": \"507f1f77bcf86cd799439013\",\n  \"driverId\": \"507f1f77bcf86cd799439014\",\n  \"priority\": \"High\",\n  \"lightInTime\": \"08:00 AM\",\n  \"lightOutTime\": \"05:00 PM\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/logistics/assign",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "logistics",
                "assign"
              ]
            },
            "description": "Assign a team (Munshi + Driver) to an enquiry for logistics execution.\n\nRequired fields: enquiryId, companyId, packingType, totalBoxes, munshiId, driverId, priority\nOptional fields: purchaseRate, lightInTime, lightOutTime\n\nNote: vehicleId is auto-resolved by the backend using the driverId. packingType must match enum: ['4H', '5H', '6H', '8H', 'CL', '7Kg', 'Other']"
          }
        }
      ]
    },
    {
      "name": "Munshi",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/munshi/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "munshi",
                "dashboard"
              ]
            },
            "description": "Get Munshi dashboard with KPIs and active assignments."
          }
        },
        {
          "name": "Get Assignments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/munshi/assignments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "munshi",
                "assignments"
              ]
            },
            "description": "Get all active assignments for the logged-in Munshi."
          }
        },
        {
          "name": "Assign Pickup Driver",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupDriverId\": \"507f1f77bcf86cd799439015\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/munshi/assignments/:id/pickup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "munshi",
                "assignments",
                ":id",
                "pickup"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Assignment ID"
                }
              ]
            },
            "description": "Assign a pickup driver to an assignment. Transitions assignmentStatus from PENDING to IN_PROGRESS."
          }
        },
        {
          "name": "Submit Packing Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "box4H",
                  "value": "100",
                  "type": "text"
                },
                {
                  "key": "box5H",
                  "value": "80",
                  "type": "text"
                },
                {
                  "key": "box6H",
                  "value": "200",
                  "type": "text"
                },
                {
                  "key": "box8H",
                  "value": "150",
                  "type": "text"
                },
                {
                  "key": "boxCL",
                  "value": "0",
                  "type": "text"
                },
                {
                  "key": "box7Kg",
                  "value": "0",
                  "type": "text"
                },
                {
                  "key": "boxOther",
                  "value": "0",
                  "type": "text"
                },
                {
                  "key": "totalBoxes",
                  "value": "530",
                  "type": "text"
                },
                {
                  "key": "wastageKg",
                  "value": "0",
                  "type": "text"
                },
                {
                  "key": "wastageReason",
                  "value": "",
                  "type": "text"
                },
                {
                  "key": "remarks",
                  "value": "Packing complete",
                  "type": "text"
                },
                {
                  "key": "lineNo",
                  "value": "A1",
                  "type": "text"
                },
                {
                  "key": "teamName",
                  "value": "Team 1",
                  "type": "text"
                },
                {
                  "key": "brandId",
                  "value": "507f1f77bcf86cd799439016",
                  "type": "text"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "description": "Packing photos (up to 10 files)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/munshi/packing/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "munshi",
                "packing",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Assignment ID"
                }
              ]
            },
            "description": "Submit a packing report with box counts and photos. Updates assignmentStatus to COMPLETED and Packing status to SUBMITTED."
          }
        },
        {
          "name": "Get Packing Report (Fetch for Edit/Reject)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/munshi/assignments/:assignmentId/packing",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "munshi",
                "assignments",
                ":assignmentId",
                "packing"
              ],
              "variable": [
                {
                  "key": "assignmentId",
                  "value": "",
                  "description": "Assignment ID"
                }
              ]
            },
            "description": "Fetch an existing packing report including previous box counts and the OM's rejection remark (omRemark). Used before resubmitting a rejected report."
          }
        },
        {
          "name": "Update Packing Report (Resubmit)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "box4H",
                  "value": "120",
                  "type": "text"
                },
                {
                  "key": "box5H",
                  "value": "100",
                  "type": "text"
                },
                {
                  "key": "box6H",
                  "value": "210",
                  "type": "text"
                },
                {
                  "key": "box8H",
                  "value": "170",
                  "type": "text"
                },
                {
                  "key": "boxCL",
                  "value": "0",
                  "type": "text"
                },
                {
                  "key": "box7Kg",
                  "value": "0",
                  "type": "text"
                },
                {
                  "key": "boxOther",
                  "value": "0",
                  "type": "text"
                },
                {
                  "key": "totalBoxes",
                  "value": "600",
                  "type": "text"
                },
                {
                  "key": "wastageKg",
                  "value": "5",
                  "type": "text"
                },
                {
                  "key": "wastageReason",
                  "value": "Damaged during transport",
                  "type": "text"
                },
                {
                  "key": "remarks",
                  "value": "Corrected counts",
                  "type": "text"
                },
                {
                  "key": "lineNo",
                  "value": "A1",
                  "type": "text"
                },
                {
                  "key": "teamName",
                  "value": "Team 1",
                  "type": "text"
                },
                {
                  "key": "brandId",
                  "value": "507f1f77bcf86cd799439016",
                  "type": "text"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "description": "New packing photos (optional - replaces old ones if provided)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/munshi/assignments/:assignmentId/packing",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "munshi",
                "assignments",
                ":assignmentId",
                "packing"
              ],
              "variable": [
                {
                  "key": "assignmentId",
                  "value": "",
                  "description": "Assignment ID"
                }
              ]
            },
            "description": "Resubmit a rejected packing report with corrected box counts and optional new photos. Updates Packing status back to SUBMITTED, clears omRemark, and sets Logistics assignmentStatus to COMPLETED."
          }
        },
        {
          "name": "Get Reports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/munshi/reports?month=4&year=2026",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "munshi",
                "reports"
              ],
              "query": [
                {
                  "key": "month",
                  "value": "4",
                  "description": "Month (1-12), defaults to current"
                },
                {
                  "key": "year",
                  "value": "2026",
                  "description": "Year, defaults to current"
                }
              ]
            },
            "description": "Get Munshi earnings/activity reports for a specific month."
          }
        },
        {
          "name": "Rollover Assignment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Need to extend to next day\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/munshi/assignments/:id/rollover",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "munshi",
                "assignments",
                ":id",
                "rollover"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Assignment ID"
                }
              ]
            },
            "description": "Rollover an assignment to the next day. Creates a new assignment with extended timeline."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
