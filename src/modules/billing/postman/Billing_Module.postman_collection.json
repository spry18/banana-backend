            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/billing/farmer/bills/{{farmer_bill_id}}/share",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceToken\": \"FCM_DEVICE_TOKEN_HERE\",\n  \"medium\": \"firebase\"\n}"
            }
          }
        }
