    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_ADMIN_JWT_TOKEN",
      "type": "string"
    },
    {
      "key": "farmer_bill_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "company_bill_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "farmer_payment_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "company_payment_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "eicher_trip_id",
      "value": "",
