    {
      "key": "procurement_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "fuel_entry_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "agent_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "employee_id",
      "value": "",
      "type": "string"
    }
