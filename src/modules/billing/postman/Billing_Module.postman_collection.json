{
  "info": {
    "name": "Billing Module — Banana Transport",
    "_postman_id": "billing-module-v1",
    "description": "Complete API collection for the isolated Billing Module (src/modules/billing/). All routes are prefixed with /api/billing. All requests require Bearer token authentication (Admin role).",
