            "url": "{{base_url}}/api/billing/master/companies"
          }
        },
        {
          "name": "GET Vehicles",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/master/vehicles"
          }
        }
      ]
    },
    {
      "name": "01 — Dashboard",
      "item": [
        {
          "name": "GET Summary",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/dashboard/summary?date=2025-01-15"
          }
        },
        {
          "name": "GET Sales by Company",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/dashboard/sales-by-company?date=2025-01-15"
          }
        },
        {
          "name": "GET Overdue Farmers",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/dashboard/overdue-farmers?minDays=25"
          }
