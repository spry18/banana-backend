        {
          "name": "GET Outstanding Chart",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/dashboard/outstanding-chart"
          }
        }
      ]
    },
    {
      "name": "02 — Farmer Bills",
      "item": [
        {
          "name": "GET All Farmer Bills",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/farmer/bills?search=&date=&status=&page=1&limit=20"
          }
        },
        {
          "name": "GET Farmer Bills Summary",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/farmer/bills/summary"
          }
        },
        {
          "name": "GET Farmer Bills History",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/farmer/bills/history?page=1&limit=20"
          }
        },
        {
          "name": "POST Create Farmer Bill",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/billing/farmer/bills",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-01-15\",\n  \"farmerName\": \"Ramesh Patil\",\n  \"farmerContact\": \"9876543210\",\n  \"location\": \"Nashik\",\n  \"company\": \"Sahyadri Farms\",\n  \"vehicleNo\": \"MH15AB1234\",\n  \"packingType\": \"13 KG\",\n  \"boxes\": 500,\n  \"totalWeight\": 6500,\n  \"grossWeight\": 13.0,\n  \"wastage\": 50,\n  \"netWeight\": 6450,\n  \"danda\": 10,\n  \"remainingWeight\": 6440,\n  \"rate\": 22,\n  \"transport\": 5000,\n  \"initialAmount\": 141680,\n  \"totalAmount\": 141680,\n  \"netPayable\": 136680,\n  \"note\": \"First batch of season\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('farmer_bill_id', res.data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Farmer Bill by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/farmer/bills/{{farmer_bill_id}}"
          }
        },
        {
          "name": "PATCH Update Farmer Bill",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/billing/farmer/bills/{{farmer_bill_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SENT\",\n  \"sentDate\": \"2025-01-15\"\n}"
            }
          }
        },
        {
          "name": "GET Farmer Bill PDF (Generate & Upload to S3)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/farmer/bills/{{farmer_bill_id}}/pdf"
          }
        },
        {
          "name": "GET Farmer Bill Receipt",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/billing/farmer/bills/{{farmer_bill_id}}/receipt"
          }
        },
        {
