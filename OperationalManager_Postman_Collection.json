                                    "if (res.token) {",
                                    "  pm.collectionVariables.set('omToken', res.token);",
                                    "  console.log('OM Token captured:', res.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"mobileNo\": \"0000000003\",\n  \"password\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/users/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "login"
                            ]
                        },
                        "description": "Login and auto-capture token into {{omToken}} via test script."
                    }
                },
                {
                    "name": "GET My Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/users/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "me"
                            ]
                        },
                        "description": "Returns the logged-in OM's profile (name, role, mobile)."
                    }
                },
                {
                    "name": "POST Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/users/logout",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "logout"
                            ]
                        },
                        "description": "Writes a LOGOUT audit log entry. Client must delete the stored token after this call (JWT is stateless)."
                    }
                }
            ]
        },
        {
            "name": "1. Dashboard",
            "item": [
                {
                    "name": "GET OM Dashboard",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/operational-manager/dashboard",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "operational-manager",
                                "dashboard"
                            ]
                        },
                        "description": "Returns KPIs: fixedPlots (ready to assign), teamsAssigned, activeTrips (pending review), approvedTrips, pendingReview. Also returns recentActivity (last 5 assignments with farmer + team details)."
                    }
                }
            ]
        },
        {
            "name": "2. Plots Pipeline",
            "item": [
                {
                    "name": "GET Plots — Unassigned (RATE_FIXED, no logistics yet)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/operational-manager/plots?stage=Unassigned&page=1&limit=20",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "operational-manager",
                                "plots"
                            ],
                            "query": [
                                {
                                    "key": "stage",
                                    "value": "Unassigned"
                                },
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                },
                                {
                                    "key": "search",
                                    "value": "",
                                    "disabled": true
                                }
                            ]
                        },
                        "description": "Returns RATE_FIXED enquiries that have no Logistics record yet. These are the plots the OM needs to assign a team to."
                    }
                },
                {
                    "name": "GET Plots — All (Full Active Workload)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/operational-manager/plots?stage=All&page=1&limit=20",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "operational-manager",
                                "plots"
                            ],
                            "query": [
                                {
                                    "key": "stage",
                                    "value": "All"
                                },
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                },
                                {
                                    "key": "search",
                                    "value": "",
                                    "disabled": true
                                }
                            ]
                        },
                        "description": "NEW — Returns the OM's full active workload in a single request.\n\nIncludes enquiries with status RATE_FIXED, ASSIGNED (legacy selector), or IN_PROGRESS (dispatched).\nEach record includes a `logistics` key containing the assigned team (munshi, driver, vehicle, schedule), or `null` if not yet assigned.\n\nSecurity: `purchaseRate` is NEVER returned in any logistics object.\nEnquiry object includes `farmerMobile` for direct farmer contact.\n\nThis is the DEFAULT view (no ?stage= param also returns stage=All)."
                    }
                },
                {
                    "name": "GET Plots — Assigned (Teams dispatched)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/operational-manager/plots?stage=Assigned&page=1&limit=20",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "operational-manager",
                                "plots"
                            ],
                            "query": [
                                {
                                    "key": "stage",
                                    "value": "Assigned"
                                },
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                }
                            ]
                        },
                        "description": "Returns Logistics assignments where assignmentStatus is PENDING or IN_PROGRESS. The team has been assigned and dispatch is either awaiting pickup driver assignment or in progress.\n\nEnquiry object now includes `farmerMobile` for direct farmer contact.\nSecurity: `purchaseRate` is excluded from all logistics objects."
                    }
                },
                {
                    "name": "GET Plots — Complete (OM Reviewed)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/operational-manager/plots?stage=Complete&page=1&limit=20",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "operational-manager",
                                "plots"
                            ],
                            "query": [
                                {
                                    "key": "stage",
                                    "value": "Complete"
                                },
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                }
                            ]
                        },
                        "description": "Returns assignments where assignmentStatus is COMPLETED, REJECTED, or APPROVED. These represent all assignments that have completed the OM review phase (either accepted as-is, rejected with notes for resubmission, or finally approved/locked for Finance).\n\nEnquiry object now includes `farmerMobile` for direct farmer contact.\nSecurity: `purchaseRate` is excluded from all logistics objects.\n\nUse this to show OM's full history of reviewed assignments across all review states."
                    }
                }
            ]
        },
        {
            "name": "3. Assignments",
            "item": [
                {
                    "name": "GET Form Dropdowns (Munshi, Driver, Vehicle, Company)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/master-data/dropdowns",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "master-data",
                                "dropdowns"
                            ]
                        },
                        "description": "Call on form load to populate all select boxes. Returns:\n- companies[], agents[], generations[], selectors[], brands[]\n- eicherDrivers[] — each with { _id, firstName, lastName, mobileNo, vehicleId: { vehicleNumber, vehicleType } }\n- pickupDrivers[] — same shape as eicherDrivers\n\nDrivers now include their linked vehicle so the frontend can display vehicle number alongside driver name without a separate call."
                    }
                },
                {
                    "name": "POST Assign Logistics Team",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "if (res._id) {",
                                    "  pm.collectionVariables.set('assignmentId', res._id);",
                                    "  console.log('Assignment ID captured:', res._id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"enquiryId\": \"{{enquiryId}}\",\n  \"companyId\": \"{{companyId}}\",\n  \"purchaseRate\": 918,\n  \"packingType\": \"13.5Kg\",\n  \"totalBoxes\": 450,\n  \"teamName\": \"E2E Crew North-04\",\n  \"munshiId\": \"{{munshiId}}\",\n  \"driverId\": \"{{driverId}}\",\n  \"priority\": \"HIGH\",\n  \"lightInTime\": \"04:45 AM\",\n  \"lightOutTime\": \"06:30 AM\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/logistics/assign",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "logistics",
                                "assign"
                            ]
                        },
                        "description": "Assigns a Munshi + Driver team to a RATE_FIXED enquiry.\n\n## FE Update (2026-04-03)\n\n**vehicleId / vehicleNumber — AUTO-RESOLVED.**\nBackend auto-resolves from driver.vehicleId. If driver has no vehicle linked, returns 400.\n\n**Enquiry Override** — companyId, packingType, totalBoxes are written back to the Enquiry document to keep it as the source of truth.\n\n**packingType** enum: '4H', '5H', '6H', '8H', 'CL', '7Kg', 'Other'\n**totalBoxes** — Required. Total number of boxes for this assignment.\n\n**purchaseRate** — Optional (no longer required).\n**lightInTime / lightOutTime** — Optional. Notification shows 'TBD' if omitted.\n\nTriggers WhatsApp alerts to Munshi, Driver, and Farmer.\nTest script captures _id into {{assignmentId}}."
                    }
                },
                {
                    "name": "GET Assignment by ID (Full Detail)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/logistics/{{assignmentId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "logistics",
                                "{{assignmentId}}"
                            ]
                        },
                        "description": "Returns a single logistics assignment with all references fully populated.\n\n## Populated Fields:\n- **enquiryId** — Full enquiry record including:\n  - **fieldOwnerId** → { firstName, lastName, mobileNo, role }\n  - **assignedSelectorId** → { firstName, lastName, mobileNo, role }\n- **companyId** — Full company record (companyName, legalName, taxId, headquarters)\n- **munshiId** → { firstName, lastName, mobileNo }\n- **driverId** → { firstName, lastName, mobileNo, vehicleId: { vehicleNumber, vehicleType } }\n- **vehicleId** — Full vehicle record (vehicleNumber, vehicleType, isActive)\n\n## Access:\nRestricted to Admin and Operational Manager roles only."
                    }
                }
            ]
        },
        {
            "name": "4. Execution Monitoring & Approvals",
            "item": [
                {
                    "name": "GET Execution Detail (Merged Assignment + Trip + Packing)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/execution/{{assignmentId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "execution",
                                "{{assignmentId}}"
                            ]
                        },
                        "description": "Returns a single unified JSON containing:\n- `assignment`: Full logistics record (company, munshi, driver, vehicle, light times)\n- `trip`: Driver's submitted report (KM, tolls, fuel slip, farmer box breakdown) + reviewStatus\n- `packing`: Munshi's packing report (box counts by type, wastage, brand)\n- `executionStatus`: { packingSubmitted, tripSubmitted, reviewStatus }\n\nValues are null if the respective team member hasn't submitted yet."
                    }
                },
                {
                    "name": "PATCH Approve Execution Report",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"reviewStatus\": \"APPROVED\",\n  \"reviewNote\":   \"All documents verified. KM and box counts match packing report.\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/execution/{{assignmentId}}/review",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "execution",
                                "{{assignmentId}}",
                                "review"
                            ]
                        },
                        "description": "PREREQUISITE: The Driver must have submitted their Trip report first (tripSubmitted = true in executionStatus).\n\nApproves the trip report. Sets reviewStatus = APPROVED, stores reviewedBy = OM's userId, logs the audit action."
                    }
                },
                {
                    "name": "PATCH Reject Execution Report",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"reviewStatus\": \"REJECTED\",\n  \"reviewNote\":   \"Diesel slip missing. Driver must re-upload and resubmit.\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/execution/{{assignmentId}}/review",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "execution",
                                "{{assignmentId}}",
                                "review"
                            ]
                        },
                        "description": "Rejects the trip report. reviewNote is REQUIRED when rejecting — this note is shown to the driver as the rejection reason."
                    }
                }
            ]
        },
        {
            "name": "4.5. Packing Report Rejection",
            "item": [
                {
                    "name": "POST Reject Packing Report (Request Resubmit)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"remark\": \"Box counts do not match the photos. Please fix and resubmit.\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/operational-manager/assignments/{{assignmentId}}/reject",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "operational-manager",
                                "assignments",
                                "{{assignmentId}}",
                                "reject"
                            ]
                        },
                        "description": "Rejects a submitted packing report and requests Munshi to resubmit.\n\n## Side Effects:\n- Packing status → REJECTED\n- Logistics assignmentStatus → REJECTED\n- Packing.omRemark = the remark text (shown to Munshi)\n\n## Munshi Workflow:\n1. Munshi receives notification that their packing report was rejected\n2. Munshi calls GET /api/munshi/assignments/{{assignmentId}}/packing to fetch the report + see omRemark\n3. Munshi corrects the box counts and calls PUT /api/munshi/assignments/{{assignmentId}}/packing to resubmit\n4. Resubmission clears omRemark and sets assignmentStatus back to COMPLETED\n\n**remark** is REQUIRED — describe what needs to be corrected."
                    }
                },
                {
                    "name": "POST Approve Packing Report (Final Lock)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"approvalNote\": \"E2E Apr 2026: packing vs photos OK — release to finance.\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/operational-manager/assignments/{{assignmentId}}/approve",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "operational-manager",
                                "assignments",
                                "{{assignmentId}}",
                                "approve"
                            ]
                        },
                        "description": "Final approval for the packing report. This locks the assignment into APPROVED status.\n\n## Prerequisites:\n- Packing status must be SUBMITTED (Munshi has already resubmitted after rejection, or first submission is good)\n- Assignment must belong to an OM (cannot be re-edited after approval)\n\n## Side Effects:\n- Packing status → APPROVED (locked)\n- Logistics assignmentStatus → APPROVED\n- **Parent Enquiry.status → COMPLETED** (terminal closure for this plot)\n- Munshi can no longer edit or resubmit once approved\n\n**approvalNote** is OPTIONAL — Finance / audit notes.\n\n## 4-Step Packing Lifecycle:\n1. **Munshi Submits** → Packing = SUBMITTED, Assignment = COMPLETED\n2. **OM Rejects** (optional) → Packing = REJECTED, Assignment = REJECTED + omRemark\n3. **Munshi Resubmits** → Packing = SUBMITTED, Assignment = COMPLETED\n4. **OM Approves** → Packing = APPROVED, Assignment = APPROVED, **Enquiry COMPLETED**\n\nDriver trip submit does **not** set Enquiry COMPLETED."
                    }
                }
            ]
        },
        {
            "name": "5. Diesel Advance",
            "item": [
                {
                    "name": "POST Issue Diesel Advance to Driver",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "if (res._id) {",
                                    "  console.log('Diesel Advance ID:', res._id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "driverId",
                                    "value": "{{driverId}}",
                                    "type": "text",
                                    "description": "MongoDB _id of the Driver user"
                                },
                                {
                                    "key": "amount",
                                    "value": "2500",
                                    "type": "text",
                                    "description": "Advance amount in ₹ INR"
                                },
                                {
                                    "key": "vehicleNumber",
                                    "value": "",
                                    "type": "text",
                                    "description": "OPTIONAL — override vehicle number. If omitted, auto-resolved from driver's linked vehicleId.",
                                    "disabled": true
                                },
                                {
                                    "key": "remark",
                                    "value": "Fuel for Solapur run",
                                    "type": "text",
                                    "description": "Optional reason/notes"
                                },
                                {
                                    "key": "assignmentId",
                                    "value": "{{assignmentId}}",
                                    "type": "text",
                                    "description": "Optional — link to a logistics assignment",
                                    "disabled": true
                                },
                                {
                                    "key": "receiptPhoto",
                                    "src": "",
                                    "type": "file",
                                    "description": "Optional — photo of advance receipt"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/diesel-advance",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "diesel-advance"
                            ]
                        },
                        "description": "Issues a fuel advance to the driver.\n\nvehicleNumber is now OPTIONAL — it is auto-resolved from the driver's linked vehicleId.vehicleNumber. Only send vehicleNumber if the driver is using a different vehicle than their default (edge case).\n\nIf the driver has no vehicle linked AND no vehicleNumber in body → returns 400 with a helpful message.\n\nTriggers WhatsApp receipt to the driver's registered mobile. Audit log is created automatically."
                    }
                },
                {
                    "name": "GET Diesel Advance History",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{omToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/diesel-advance?page=1&limit=20",
