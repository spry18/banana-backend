                                    "description": "true if the line/route was cancelled"
                                },
                                {
                                    "key": "teamMembers",
                                    "value": "Raju, Suresh",
                                    "type": "text",
                                    "description": "Optional â€” names of other crew members"
                                },
                                {
                                    "key": "farmerBoxBreakdown",
                                    "value": "[{\"farmerName\": \"Farmer A\", \"boxCount\": 80}, {\"farmerName\": \"Farmer B\", \"boxCount\": 60}]",
                                    "type": "text",
                                    "description": "JSON string â€” breakdown of boxes per farmer loaded on this truck"
                                },
                                {
                                    "key": "weightSlipPhoto",
                                    "type": "file",
                                    "src": [],
                                    "description": "đź“· Required â€” Weight Bridge slip photo"
                                },
                                {
                                    "key": "dieselSlipPhoto",
                                    "type": "file",
                                    "src": [],
                                    "description": "đź“· Required â€” Diesel receipt photo"
                                },
                                {
                                    "key": "unloadSlipPhoto",
                                    "type": "file",
                                    "src": [],
                                    "description": "đź“· Required â€” Unloading receipt / delivery confirmation photo"
                                },
                                {
                                    "key": "endKmPhoto",
                                    "type": "file",
                                    "src": [],
                                    "description": "đź“· Recommended â€” Odometer photo at destination"
                                }
