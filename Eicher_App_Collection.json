                                    "value": "Coimbatore Depot",
                                    "type": "text",
                                    "description": "Starting point of the route"
                                },
                                {
                                    "key": "midRoute",
                                    "value": "Salem Bypass",
                                    "type": "text",
                                    "description": "Optional mid-route stop name"
                                },
                                {
                                    "key": "destination",
                                    "value": "Chennai Cold Storage",
                                    "type": "text",
                                    "description": "Final delivery destination"
                                },
                                {
                                    "key": "totalKm",
                                    "value": "500",
                                    "type": "text",
                                    "description": "Total kilometers driven for this trip"
                                },
                                {
                                    "key": "tollExpense",
                                    "value": "750",
                                    "type": "text",
                                    "description": "Total toll paid (â‚ą)"
                                },
                                {
                                    "key": "isHault",
                                    "value": "false",
                                    "type": "text",
                                    "description": "true if the truck was halted/parked overnight"
                                },
                                {
