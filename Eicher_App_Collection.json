            ]
        },
        {
            "name": "Notifications",
            "description": "In-app notification feed â€” Driver (Eicher) sees only their own notifications (scoped by recipientId). Auto-triggered by: Logistics assignment (LOGISTICS_ASSIGNED), extra vehicle added (EXTRA_VEHICLE_ADDED), packing approved.",
            "item": [
