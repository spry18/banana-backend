                        "url": {
                            "raw": "{{baseUrl}}/api/driver/trips/{{assignmentId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "driver",
                                "trips",
                                "{{assignmentId}}"
                            ]
                        },
                        "description": "Submit the final trip report for this assignment.\n\n**Constraints:**\n- Only one Trip per `assignmentId` per driver. Duplicate submission returns `400`.\n- The `driverType` is **auto-detected** from the JWT role: `driver eicher` â†’ `Eicher`.\n- This does **NOT** close the Enquiry. The OM must approve the Packing report to set `Enquiry.status = COMPLETED`.\n\n**After submission:**\n- `Logistics.assignmentStatus` will be updated to `COMPLETED` by the Trip's OM review approval.\n- A PDF system report is auto-generated (`systemReportUrl`)."
                    },
                    "response": []
                },
                {
                    "name": "PATCH Update Trip Report (After Rejection)",
                    "request": {
                        "method": "PATCH",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "totalKm",
                                    "value": "510",
                                    "type": "text",
                                    "description": "Corrected total km"
                                },
                                {
                                    "key": "tollExpense",
                                    "value": "800",
                                    "type": "text",
                                    "description": "Corrected toll amount"
                                },
                                {
                                    "key": "weightSlipPhoto",
                                    "type": "file",
                                    "src": [],
                                    "description": "đź“· Re-upload corrected weight slip"
                                },
                                {
                                    "key": "unloadSlipPhoto",
                                    "type": "file",
                                    "src": [],
                                    "description": "đź“· Re-upload corrected unload slip"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/driver/trips/{{tripId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "driver",
                                "trips",
                                "{{tripId}}"
                            ]
                        },
                        "description": "Update a previously submitted trip report. Only allowed if `reviewStatus` is `PENDING` or `REJECTED`.\n\nUse `:tripId` (the `_id` from the POST Submit response).\n\n**Behaviour:** If `reviewStatus` was `REJECTED`, it is automatically reset to `PENDING` so the OM reviews the corrected report.\n\nOnly supply the fields you want to change â€” unset fields are left untouched."
                    },
                    "response": []
                }
            ]
        },
