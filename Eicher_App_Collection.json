                    },
                    "response": []
                }
            ]
        },
        {
            "name": "1. Daily Log â€” Shift Start",
            "item": [
                {
                    "name": "GET Check Today Log Status",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/daily-logs/check-today",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "daily-logs",
                                "check-today"
                            ]
                        },
                        "description": "đźš¦ CALL THIS FIRST ON APP OPEN.\n\nReturns whether the current driver has already started their day:\n```json\n// Shift already started:\n{ \"isStarted\": true, \"logId\": \"<ObjectId>\", \"role\": \"driver eicher\" }\n\n// Shift not started yet:\n{ \"isStarted\": false }\n```\n- `isStarted: true`  â†’ skip the meter photo screen, go directly to Dashboard.\n- `isStarted: false` â†’ show the Start Shift / Odometer screen (Step 2)."
                    },
                    "response": []
                },
                {
                    "name": "POST Start Shift",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "startKm",
                                    "value": "46820",
                                    "type": "text",
                                    "description": "Current odometer reading (km)"
                                },
                                {
                                    "key": "vehicleNumber",
                                    "value": "MH-15-AB-1234",
                                    "type": "text",
                                    "description": "Vehicle registration number"
                                },
                                {
                                    "key": "petrolAdvance",
                                    "value": "500",
                                    "type": "text",
                                    "description": "Amount of petrol advance taken (â‚ą). Send 0 if none."
                                },
                                {
                                    "key": "startKmPhoto",
                                    "type": "file",
                                    "src": [],
                                    "description": "đź“· Required â€” Photo of odometer at start of shift"
                                },
                                {
                                    "key": "petrolReceiptPhoto",
                                    "type": "file",
                                    "src": [],
                                    "description": "đź“· Optional â€” Photo of petrol receipt if advance taken"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/daily-logs/start",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "daily-logs",
                                "start"
                            ]
                        },
                        "description": "Starts the daily shift log. Each driver can only have ONE active log per day.\n\n**Constraint:** Returns `400` if a log already exists for today â€” use `check-today` first.\n\n**Response:** The created DailyLog document including `_id` (the logId)."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "2. Dashboard",
            "item": [
                {
                    "name": "GET Driver Dashboard",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/driver/dashboard",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "driver",
                                "dashboard"
                            ]
                        },
                        "description": "Returns:\n- `kpis` â€” counts of active / completed / cancelled assignments scoped to this driver\n- `activeAssignments[]` â€” all Logistics records where `driverId` OR `pickupDriverId` = this user AND `assignmentStatus` is `PENDING`\n\nEach assignment includes full farmer info, munshi, vehicle details.\n\nđź‘‰ Save `activeAssignments[0]._id` into `{{assignmentId}}` to proceed with trip submission."
                    },
                    "response": []
                },
                {
                    "name": "GET My Assignments (Simple List)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/driver/assignments",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "driver",
                                "assignments"
                            ]
                        },
                        "description": "Alternative to Dashboard â€” returns a flat array of active (PENDING) assignment documents. Useful for drop-down assignment picker screens."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "3. Trip Report",
            "item": [
                {
                    "name": "POST Submit Trip Report",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
